{
  "name": "bizlin-chat",
  "version": "0.0.4",
  "description": "Open-source WhatsApp Cloud API Team Inbox by Bizlin Technologies",
  "main": "backend/src/index.ts",
  "bin": {
    "bizlin-chat": "bin/bizlin-chat.js"
  },
  "files": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "ts-node --transpile-only backend/src/index.ts",
    "dev:frontend": "cd frontend && next dev",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "cd frontend && next build",
    "build": "npm run build:backend && npm run build:frontend",
    "start:backend": "node backend/dist/index.js",
    "start:frontend": "cd frontend && next start -p 3000",
    "start": "concurrently \"npm:start:backend\" \"npm:start:frontend\"",
    "deploy": "npm run build && npm run deploy:docker",
    "deploy:docker": "docker build -t bizlin-chat:latest . && docker push bizlin-chat:latest",
    "deploy:npm": "npm run build && npm publish",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "zchat",
    "whatsapp",
    "team inbox",
    "bizlin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bizlinsolutions/zchat.git"
  },
  "author": "Bizlin Technologies",
  "license": "MIT",
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "axios": "1.5.0",
    "bcryptjs": "2.4.3",
    "bufferutil": "^4.0.8",
    "cors": "2.8.5",
    "express": "4.18.2",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "next": "13.4.7",
    "pg": "8.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.12.0",
    "socket.io": "4.7.2",
    "socket.io-client": "4.7.2",
    "sqlite3": "5.1.6",
    "utf-8-validate": "^6.0.0",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.12",
    "@types/react-dom": "^18.2.5",
    "@types/uuid": "^9.0.2",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.1",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.8",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
